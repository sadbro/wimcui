{
  "type": "group",
  "title": "Containerized API",
  "description": "Production container architecture built on ECS Fargate. ECR stores Docker images, ALB routes HTTPS traffic to ECS tasks in private subnets, ElastiCache handles session and response caching, and RDS stores persistent data. NAT Gateway gives containers outbound internet access for ECR pulls and external API calls.",
  "resources": [
    "VPC",
    "Subnet",
    "IGW",
    "NATGateway",
    "RouteTable",
    "ECR",
    "LoadBalancer",
    "ECS",
    "ElastiCache",
    "RDS"
  ],
  "practices": [
    "Pull container images from ECR, not public Docker Hub — ECR is faster, has no rate limits, and supports image scanning on push.",
    "Run ECS tasks in private subnets. The ALB in public subnets handles inbound traffic — ECS should never be directly internet-facing.",
    "Use separate Security Groups per tier: ALB allows 443 from 0.0.0.0/0, ECS allows only from ALB SG, RDS and ElastiCache allow only from ECS SG.",
    "ElastiCache node_type should match your working set size. A cache miss is a full database round-trip — size generously and monitor evictions.",
    "RDS requires subnets in at least 2 AZs for a DB subnet group. Always provide two private subnets from different AZs.",
    "Store database credentials in Secrets Manager and inject them as ECS environment variables — never bake secrets into container images."
  ],
  "configNotes": [
    "ECS subnets must reference private subnet node IDs.",
    "ALB subnets must reference public subnet node IDs (2 minimum, different AZs).",
    "RDS subnets must reference private subnet node IDs (2 minimum, different AZs) for DB subnet group.",
    "ElastiCache subnets must reference at least 2 private subnet node IDs in different AZs — AWS requires a subnet group with multi-AZ coverage even for single-node clusters.",
    "NAT Gateway must be in a public subnet — it needs IGW access to route outbound traffic."
  ],
  "example": {
