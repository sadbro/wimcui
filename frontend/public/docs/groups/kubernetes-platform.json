{
  "type": "group",
  "title": "Kubernetes Platform",
  "description": "Production EKS cluster with managed node groups. The control plane (EKSCluster) spans private subnets across two AZs — a hard EKS requirement. Worker nodes (EKSNodeGroup) run in private subnets and pull traffic via an internet-facing ALB in public subnets. NAT Gateway gives nodes outbound access for image pulls and API calls.",
  "resources": [
    "VPC",
    "Subnet",
    "IGW",
    "NATGateway",
    "RouteTable",
    "LoadBalancer",
    "EKSCluster",
    "EKSNodeGroup"
  ],
  "practices": [
    "EKS control plane requires subnets in at least 2 AZs — this is a hard AWS requirement, not a best practice.",
    "Place node groups in private subnets. Worker nodes should never be directly internet-facing.",
    "The ALB handles ingress via the AWS Load Balancer Controller running on the cluster — traffic flows internet → ALB → ingress controller pods → application pods.",
    "Use separate IAM roles for the cluster and node groups. Cluster role trusts eks.amazonaws.com; node role trusts ec2.amazonaws.com.",
    "Node group IAM role needs AmazonEKSWorkerNodePolicy, AmazonEKS_CNI_Policy, and AmazonEC2ContainerRegistryReadOnly at minimum.",
    "Set min_size >= 2 for production to survive node replacement during upgrades. desired_size and max_size should account for peak load."
  ],
  "configNotes": [
    "EKSCluster subnets must reference at least 2 private subnet node IDs in different AZs.",
    "EKSNodeGroup parentNodeId must reference the EKSCluster node ID — this links them for HCL generation.",
    "EKSNodeGroup subnets must reference private subnet node IDs.",
    "ALB subnets must reference public subnet node IDs (2 minimum, different AZs).",
    "kubernetes_version must be set on EKSCluster — check AWS docs for currently supported versions."
  ],
  "example": {
    "nodes": [
      {
        "id": "n1",
        "position": { "x": 400, "y": 0 },
        "data": {
          "resourceType": "VPC",
          "label": "K8s VPC",
          "config": {
            "cidr": "10.0.0.0/16",
            "name": "k8s-vpc"
          }
        }
      },
      {
        "id": "n2",
        "position": { "x": 100, "y": 160 },
        "data": {
          "resourceType": "Subnet",
          "label": "Public AZ-A",
          "config": {
            "cidr": "10.0.1.0/24",
            "name": "pub-a",
            "visibility": "Public",
            "availability_zone": "us-east-1a",
            "vpcId": "n1"
          }
        }
      },
      {
        "id": "n3",
        "position": { "x": 500, "y": 160 },
        "data": {
          "resourceType": "Subnet",
          "label": "Public AZ-B",
          "config": {
            "cidr": "10.0.2.0/24",
            "name": "pub-b",
            "visibility": "Public",
            "availability_zone": "us-east-1b",
            "vpcId": "n1"
          }
        }
      },
      {
        "id": "n4",
        "position": { "x": 100, "y": 400 },
        "data": {
          "resourceType": "Subnet",
          "label": "Private AZ-A",
          "config": {
            "cidr": "10.0.10.0/24",
            "name": "priv-a",
            "visibility": "Private",
            "availability_zone": "us-east-1a",
            "vpcId": "n1"
          }
        }
      },
      {
        "id": "n5",
        "position": { "x": 500, "y": 400 },
        "data": {
          "resourceType": "Subnet",
          "label": "Private AZ-B",
          "config": {
            "cidr": "10.0.11.0/24",
            "name": "priv-b",
            "visibility": "Private",
            "availability_zone": "us-east-1b",
            "vpcId": "n1"
          }
        }
      },
      {
        "id": "n6",
        "position": { "x": 820, "y": 0 },
        "data": {
          "resourceType": "IGW",
          "label": "Internet GW",
          "config": {
            "name": "k8s-igw",
