            "endpoint_public_access": "true",
            "endpoint_private_access": "true",
            "enabled_cluster_log_types": "api,audit",
            "iam_role_id": "role-eks-n11",
            "sg_ids": ["sg-n11"],
            "subnets": ["n4", "n5"]
          }
        }
      },
      {
        "id": "n12",
        "position": { "x": 500, "y": 560 },
        "data": {
          "resourceType": "EKSNodeGroup",
