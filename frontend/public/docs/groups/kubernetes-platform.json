            "parentNodeId": "n11",
            "instance_type": "t3.medium",
            "min_size": "2",
            "max_size": "6",
            "desired_size": "3",
            "ami_type": "AL2_x86_64",
            "iam_role_id": "role-ng-n12",
            "subnets": ["n4", "n5"]
          }
        }
      }
    ],
