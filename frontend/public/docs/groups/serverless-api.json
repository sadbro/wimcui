{
  "type": "group",
  "title": "Serverless API",
  "description": "Zero-infrastructure API backend. API Gateway handles routing and throttling, Lambda runs business logic, DynamoDB stores data. No servers to manage, no VPC needed, pay only for what you use. Ideal for event-driven backends, webhooks, and low-to-moderate traffic APIs.",
  "resources": [
    "APIGateway",
    "Lambda",
    "DynamoDB",
    "SQS"
  ],
  "practices": [
    "Don't put Lambda in a VPC unless it needs to access private resources like RDS — VPC adds cold start latency and NAT Gateway costs.",
    "Use API Gateway HTTP API (v2) over REST API for simple use cases — it's cheaper and has lower latency.",
    "Lambda IAM roles should follow least-privilege: only grant dynamodb:GetItem, PutItem, Query on the specific table ARN.",
    "Use DynamoDB on-demand mode for unpredictable traffic. Switch to provisioned only when you have stable, predictable load.",
    "Add SQS between synchronous API responses and async processing. Return 202 Accepted immediately, process in background.",
    "Set Lambda timeout higher than API Gateway timeout (29s max for API Gateway). Otherwise API GW times out but Lambda keeps running."
  ],
  "configNotes": [
    "API Gateway needs a name and stage (e.g., prod).",
    "Lambda needs runtime, handler, memory, and timeout configured.",
    "DynamoDB needs a table name and partition key.",
    "SQS is optional — add it for async processing patterns."
  ],
  "example": {
    "nodes": [
      {
        "id": "n1",
        "position": {
          "x": 100,
          "y": 150
        },
        "data": {
          "resourceType": "APIGateway",
          "label": "Items API",
          "config": {
            "name": "items-api",
            "api_name": "my-api",
            "api_type": "REST",
            "stage_name": "prod"
          }
        }
      },
      {
        "id": "n2",
        "position": {
          "x": 350,
          "y": 80
        },
        "data": {
          "resourceType": "Lambda",
          "label": "GET /items",
          "config": {
            "runtime": "nodejs20.x",
            "handler": "index.getItems",
            "memory_size": "256",
            "timeout": "10",
            "name": "get-items",
            "sg_ids": [
              "sg-n2"
            ],
            "iam_role_id": "role-lambda-n2"
          }
        }
      },
      {
        "id": "n3",
        "position": {
          "x": 350,
          "y": 220
        },
        "data": {
          "resourceType": "Lambda",
          "label": "POST /items",
          "config": {
            "runtime": "nodejs20.x",
            "handler": "index.createItem",
            "memory_size": "256",
            "timeout": "10",
            "name": "create-item",
            "sg_ids": [
              "sg-n3"
            ],
            "iam_role_id": "role-lambda-n2"
          }
        }
      },
      {
        "id": "n4",
        "position": {
          "x": 600,
          "y": 80
        },
        "data": {
          "resourceType": "DynamoDB",
          "label": "Items Table",
          "config": {
            "name": "items-table",
            "table_name": "items",
            "billing_mode": "PAY_PER_REQUEST",
            "hash_key": "id",
            "hash_key_type": "S"
          }
        }
      },
      {
        "id": "n5",
        "position": {
          "x": 600,
          "y": 220
        },
        "data": {
          "resourceType": "SQS",
          "label": "Process Queue",
          "config": {
            "name": "item-processing-queue",
            "queue_name": "task-queue",
            "fifo": "false"
          }
        }
      }
    ],
    "edges": [
      {
        "id": "e1",
        "source": "n1",
        "target": "n2",
        "type": "traffic"
      },
      {
        "id": "e2",
        "source": "n1",
        "target": "n3",
        "type": "traffic"
      }
    ],
    "version": 1,
    "securityGroups": [
      {
        "id": "sg-n2",
        "name": "get-items-sg",
        "description": "Security group for GET /items",
        "inbound": [
          {
            "protocol": "tcp",
            "port": "443",
            "cidr": "0.0.0.0/0",
            "description": "HTTPS"
          }
        ],
        "outbound": [
          {
            "protocol": "-1",
            "port": "0",
            "cidr": "0.0.0.0/0",
            "description": "All outbound"
          }
        ]
      },
      {
        "id": "sg-n3",
        "name": "create-item-sg",
        "description": "Security group for POST /items",
        "inbound": [
          {
            "protocol": "tcp",
            "port": "443",
            "cidr": "0.0.0.0/0",
            "description": "HTTPS"
          }
        ],
        "outbound": [
          {
            "protocol": "-1",
            "port": "0",
            "cidr": "0.0.0.0/0",
            "description": "All outbound"
          }
        ]
      }
    ],
    "roles": [
      {
        "id": "role-lambda-n2",
        "name": "get-items-exec-role",
        "policies": [
          "AWSLambdaBasicExecutionRole"
        ]
      }
    ]
  }
}
