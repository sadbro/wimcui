{
  "type": "ASG",
  "title": "Auto Scaling Group",
  "description": "Automatically scales EC2 instances based on demand. Maintains desired capacity, replaces unhealthy instances, and distributes across AZs for high availability.",
  "connections": {
    "parents": [
      "Subnet"
    ],
    "trafficSources": [
      "LoadBalancer",
      "Public",
      "Route53"
    ],
    "trafficTargets": [],
    "associations": []
  },
  "practices": [
    "Set min_size >= 1 to avoid downtime during scale-up. Zero means no instances are running until demand triggers scaling.",
    "Use health_check_type = ELB, not EC2. ELB checks actual HTTP health, EC2 only checks if the VM is running.",
    "Spread across 2+ AZs for high availability. If one AZ goes down, instances in other AZs keep serving.",
    "Set health_check_grace_period long enough for your application to start. Too short = healthy instances get terminated."
  ],
  "configNotes": [
    "AMI ID is required \u2014 this is the machine image launched by the ASG.",
    "Instance type is required (e.g., t3.small).",
    "min_size, max_size, and desired_capacity are required.",
    "Subnets are required \u2014 determines which AZs instances launch in."
  ],
  "example": {
    "nodes": [
      {
        "id": "n1",
        "position": {
          "x": 250,
          "y": 0
        },
        "data": {
          "resourceType": "VPC",
          "label": "App VPC",
          "config": {
            "cidr": "10.0.0.0/16",
            "name": "app-vpc"
          }
        }
      },
      {
        "id": "n2",
        "position": {
          "x": 100,
          "y": 120
        },
        "data": {
          "resourceType": "Subnet",
          "label": "Subnet AZ-A",
          "config": {
            "cidr": "10.0.1.0/24",
            "az": "us-east-1a",
            "name": "sub-a",
            "visibility": "Private",
            "availability_zone": "us-east-1a",
            "vpcId": "n1"
          }
        }
      },
      {
        "id": "n3",
        "position": {
          "x": 400,
          "y": 120
        },
        "data": {
          "resourceType": "Subnet",
          "label": "Subnet AZ-B",
          "config": {
            "cidr": "10.0.2.0/24",
            "az": "us-east-1b",
            "name": "sub-b",
            "visibility": "Private",
            "availability_zone": "us-east-1b",
            "vpcId": "n1"
          }
        }
      },
      {
        "id": "n4",
        "position": {
          "x": 250,
          "y": 260
        },
        "data": {
          "resourceType": "LoadBalancer",
          "label": "Web ALB",
          "config": {
            "lb_type": "alb",
            "name": "web-alb",
            "load_balancer_type": "application",
            "internal": "false",
            "tg_port": "80",
            "tg_protocol": "HTTP",
            "listener_port": "443",
            "listener_protocol": "HTTPS",
            "sg_ids": [
              "sg-n4"
            ],
            "subnets": [
              "n2",
              "n3"
            ]
          }
        }
      },
      {
        "id": "n5",
        "position": {
          "x": 250,
          "y": 400
        },
        "data": {
          "resourceType": "ASG",
          "label": "Web ASG",
          "config": {
            "ami": "ami-0abcdef1234567890",
            "instance_type": "t3.small",
            "min_size": "2",
            "max_size": "6",
            "desired_capacity": "2",
            "name": "web-asg",
            "sg_ids": [
              "sg-n5"
            ],
            "iam_role_id": "role-asg-n5",
            "subnetId": "n2"
          }
        }
      }
    ],
    "edges": [
      {
        "id": "e1",
        "source": "n1",
        "target": "n2",
        "type": "structural"
      },
      {
        "id": "e2",
        "source": "n1",
        "target": "n3",
        "type": "structural"
      },
      {
        "id": "e3",
        "source": "n2",
        "target": "n4",
        "type": "structural"
      },
      {
        "id": "e4",
        "source": "n2",
        "target": "n5",
        "type": "structural"
      },
      {
        "id": "e6",
        "source": "n4",
        "target": "n5",
        "type": "traffic"
      }
    ],
    "version": 2,
    "securityGroups": [
      {
        "id": "sg-n4",
        "name": "web-alb-sg",
        "description": "Security group for Web ALB",
        "inbound": [
          {
            "protocol": "tcp",
            "port": "443",
            "cidr": "0.0.0.0/0",
            "description": "HTTPS from internet"
          }
        ],
        "outbound": [
          {
            "protocol": "tcp",
            "port": "80",
            "cidr": "sg-n5",
            "description": "To Web ASG"
          }
        ]
      },
      {
        "id": "sg-n5",
        "name": "web-asg-sg",
        "description": "Security group for Web ASG",
        "inbound": [
          {
            "protocol": "tcp",
            "port": "80",
            "cidr": "sg-n4",
            "description": "From Web ALB"
          }
        ],
        "outbound": [
          {
            "protocol": "-1",
            "port": "0",
            "cidr": "0.0.0.0/0",
            "description": "All outbound"
          }
        ]
      }
    ],
    "roles": [
      {
        "id": "role-asg-n5",
        "name": "web-asg-role",
        "policies": [
          "AmazonSSMManagedInstanceCore"
        ]
      }
    ]
  }
}