{
  "type": "DynamoDB",
  "title": "DynamoDB",
  "description": "Fully managed NoSQL database with single-digit millisecond latency. Scales automatically with on-demand mode. Accessed via IAM, not network traffic.",
  "connections": {
    "parents": [],
    "trafficSources": [],
    "trafficTargets": [],
    "associations": []
  },
  "practices": [
    "Use on-demand capacity mode unless you have predictable, steady traffic — it prevents over-provisioning.",
    "Design your partition key for even distribution. Hot partitions cause throttling regardless of capacity.",
    "Enable point-in-time recovery for production tables — it's cheap insurance against accidental deletes.",
    "Access DynamoDB via IAM roles on your compute, not embedded access keys."
  ],
  "configNotes": [
    "Table name is required.",
    "Partition key (and optional sort key) define the primary key schema.",
    "Billing mode: on-demand (pay per request) or provisioned (set read/write capacity units)."
  ],
  "example": {
    "nodes": [
      {
        "id": "n1",
        "position": {
          "x": 100,
          "y": 100
        },
        "data": {
          "resourceType": "APIGateway",
          "label": "API",
          "config": {
            "name": "crud-api",
            "api_name": "my-api",
            "api_type": "REST",
            "stage_name": "prod"
          }
        }
      },
      {
        "id": "n2",
        "position": {
          "x": 350,
          "y": 100
        },
        "data": {
          "resourceType": "Lambda",
          "label": "CRUD Handler",
          "config": {
            "runtime": "nodejs20.x",
            "name": "crud-fn",
            "handler": "index.handler",
            "memory_size": "256",
            "timeout": "30",
            "sg_ids": [
              "sg-n2"
            ],
            "iam_role_id": "role-lambda-n2"
          }
        }
      },
      {
        "id": "n3",
        "position": {
          "x": 600,
          "y": 100
        },
        "data": {
          "resourceType": "DynamoDB",
          "label": "Items Table",
          "config": {
            "name": "items-table",
            "table_name": "items",
            "billing_mode": "PAY_PER_REQUEST",
            "hash_key": "id",
            "hash_key_type": "S"
          }
        }
      }
    ],
    "edges": [
      {
        "id": "e1",
        "source": "n1",
        "target": "n2",
        "type": "traffic"
      }
    ],
    "version": 1,
    "securityGroups": [
      {
        "id": "sg-n2",
        "name": "crud-fn-sg",
        "description": "Security group for CRUD Handler",
        "inbound": [
          {
            "protocol": "tcp",
            "port": "443",
            "cidr": "0.0.0.0/0",
            "description": "HTTPS"
          }
        ],
        "outbound": [
          {
            "protocol": "-1",
            "port": "0",
            "cidr": "0.0.0.0/0",
            "description": "All outbound"
          }
        ]
      }
    ],
    "roles": [
      {
        "id": "role-lambda-n2",
        "name": "crud-fn-exec-role",
        "policies": [
          "AWSLambdaBasicExecutionRole"
        ]
      }
    ]
  }
}
