{
  "type": "EC2",
  "title": "EC2 Instance",
  "description": "An EC2 instance is a virtual server in AWS. It runs your application code and can be placed in a subnet to control network access and availability zone placement.",
  "connections": {
    "parents": [
      "Subnet"
    ],
    "trafficSources": [
      "EC2",
      "RDS",
      "LoadBalancer",
      "Public",
      "ECS",
      "Lambda",
      "APIGateway",
      "Route53"
    ],
    "trafficTargets": [
      "EC2",
      "RDS",
      "LoadBalancer",
      "ECS",
      "ElastiCache",
      "Kinesis"
    ],
    "associations": []
  },
  "practices": [
    "Always attach a Security Group \u2014 EC2 instances without SGs have no inbound access, but explicit SGs make intent clear.",
    "Use IAM instance profiles instead of hardcoded credentials; never put AWS keys on an instance.",
    "Right-size the instance type \u2014 start small and scale up based on actual utilization metrics.",
    "Place production instances in a private subnet behind a Load Balancer; only bastion hosts belong in public subnets."
  ],
  "configNotes": [
    "AMI ID is required and determines the OS and pre-installed software.",
    "Instance type is required and determines CPU, memory, and network performance.",
    "Subnet placement determines the Availability Zone \u2014 you cannot move an instance to another AZ after launch."
  ],
  "example": {
