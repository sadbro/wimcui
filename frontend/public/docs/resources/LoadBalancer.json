{
  "type": "LoadBalancer",
  "title": "Load Balancer",
  "description": "Distributes incoming traffic across multiple targets. ALB handles HTTP/HTTPS with path-based routing, NLB handles TCP/UDP with ultra-low latency.",
  "connections": {
    "parents": [
      "Subnet"
    ],
    "trafficSources": [
      "Public",
      "EC2",
      "Route53"
    ],
    "trafficTargets": [
      "EC2",
      "ECS",
      "Lambda",
      "ASG"
    ],
    "associations": []
  },
  "practices": [
    "ALB requires at least 2 subnets in different Availability Zones \u2014 this is an AWS hard requirement.",
    "Prefer ALB for HTTP/HTTPS workloads and NLB for raw TCP/UDP or extreme performance needs.",
    "Configure health checks with an appropriate path and thresholds \u2014 unhealthy targets get no traffic.",
    "Use HTTPS listeners with ACM certificates for production. Never expose HTTP-only endpoints publicly."
  ],
  "configNotes": [
    "Load balancer type (ALB or NLB) is required.",
    "Listener port and protocol must be specified.",
    "Health check path is critical for ALB \u2014 use a lightweight endpoint like /health.",
    "Must be placed in at least 2 subnets across different AZs."
  ],
