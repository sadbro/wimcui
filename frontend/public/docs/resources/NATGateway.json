{
  "type": "NATGateway",
  "title": "NAT Gateway",
  "description": "A NAT Gateway allows instances in private subnets to reach the internet for outbound traffic (e.g., software updates) while preventing unsolicited inbound connections.",
  "connections": {
    "parents": [
      "Subnet"
    ],
    "trafficSources": [],
    "trafficTargets": [],
    "associations": []
  },
  "practices": [
    "Always place a NAT Gateway in a public subnet \u2014 it needs a route to the internet via an IGW to function.",
    "Deploy one NAT Gateway per Availability Zone for high availability; a single NAT is a single point of failure.",
    "NAT Gateways incur hourly and data-processing charges \u2014 verify that private subnets actually need outbound internet before deploying.",
    "Associate an Elastic IP with the NAT Gateway for a stable outbound IP address."
  ],
  "configNotes": [
    "Must be placed in a public subnet (one with a route to an IGW).",
    "An Elastic IP allocation is required for public NAT Gateways."
  ],
