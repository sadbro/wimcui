{
  "type": "RouteTable",
  "title": "Route Table",
  "description": "A route table contains rules (routes) that determine where network traffic from subnets or gateways is directed. Each subnet must be associated with exactly one route table.",
  "connections": {
    "parents": [
      "VPC"
    ],
    "trafficSources": [],
    "trafficTargets": [],
    "associations": [
      "Subnet",
      "IGW",
      "NATGateway"
    ]
  },
  "practices": [
    "Use explicit route table associations on every subnet to prevent unexpected routing through the main route table.",
    "The main route table applies to any subnet without an explicit association \u2014 always override it with a specific one.",
    "Maintain separate route tables for public subnets (route to IGW) and private subnets (route to NAT Gateway).",
    "Keep routes as specific as possible; overly broad routes can expose resources unintentionally."
  ],
  "configNotes": [
    "Each route requires a destination CIDR block and a target (e.g., IGW, NAT Gateway, or local).",
    "A local route for the VPC CIDR is automatically included and cannot be removed."
  ],
