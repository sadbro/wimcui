{
  "type": "SecretsManager",
  "title": "Secrets Manager",
  "description": "Securely stores and rotates secrets like database credentials, API keys, and tokens. Applications retrieve secrets at runtime via API instead of hardcoding them.",
  "connections": {
    "parents": [],
    "trafficSources": [],
    "trafficTargets": [],
    "associations": [
      "RDS",
      "ECS",
      "Lambda",
      "EC2"
    ]
  },
  "practices": [
    "Store all database credentials in SecretsManager, never in environment variables or code.",
    "Enable automatic rotation for RDS credentials — SecretsManager handles it natively.",
    "Use resource-based policies to limit which IAM roles can access each secret.",
    "Cache secrets in your application to avoid API throttling — the SDK supports this natively."
  ],
  "configNotes": [
    "Secret name is required — use a descriptive path like prod/myapp/db-credentials.",
    "Rotation can be enabled for supported services (RDS, Redshift, DocumentDB).",
    "Consumers need secretsmanager:GetSecretValue IAM permission."
  ],
  "example": {
    "nodes": [
      {
        "id": "n1",
        "position": {
          "x": 250,
          "y": 50
        },
        "data": {
          "resourceType": "SecretsManager",
          "label": "DB Credentials",
          "config": {
            "name": "db-creds",
            "secret_name": "prod/db/creds"
          }
        }
      },
      {
        "id": "n2",
        "position": {
          "x": 100,
          "y": 220
        },
        "data": {
          "resourceType": "ECS",
          "label": "App Service",
          "config": {
            "name": "app-svc",
            "launch_type": "FARGATE",
            "cpu": "256",
            "memory": "512",
            "image": "nginx:latest",
            "desired_count": "2",
            "iam_role_id": "role-ecs-n2"
          }
        }
      },
      {
        "id": "n3",
        "position": {
          "x": 400,
          "y": 220
        },
        "data": {
          "resourceType": "RDS",
          "label": "Database",
          "config": {
            "engine": "postgres",
            "name": "app-db",
            "engine_version": "15.3",
            "instance_class": "db.t3.micro",
            "allocated_storage": "20",
            "username": "admin",
            "password": "changeme123!",
            "storage_encrypted": "true"
          }
        }
      }
    ],
    "edges": [
      {
        "id": "e1",
        "source": "n1",
        "target": "n2",
        "type": "association"
      },
      {
        "id": "e2",
        "source": "n1",
        "target": "n3",
        "type": "association"
      }
    ],
    "version": 1,
    "securityGroups": [],
    "roles": [
      {
        "id": "role-ecs-n2",
        "name": "app-svc-task-role",
        "policies": [
          "AmazonECSTaskExecutionRolePolicy"
        ]
      }
    ]
  }
}
